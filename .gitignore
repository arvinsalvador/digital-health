# =====================================================
# Operating System Junk Files
# =====================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*

# =====================================================
# Environment Files (NEVER COMMIT)
# =====================================================
.env
.vagrant
Vagrantfile

# =====================================================
# Writable / Runtime Files (CodeIgniter)
# =====================================================
writable/cache/*
!writable/cache/index.html

writable/logs/*
!writable/logs/index.html

writable/session/*
!writable/session/index.html

writable/uploads/*
!writable/uploads/index.html
!writable/uploads/.gitkeep

writable/debugbar/*
!writable/debugbar/index.html

php_errors.log

# =====================================================
# User Guide Temp Files
# =====================================================
user_guide_src/build/*
user_guide_src/cilexer/build/*
user_guide_src/cilexer/dist/*
user_guide_src/cilexer/pycilexer.egg-info/*

# =====================================================
# Test / Coverage Files
# =====================================================
tests/coverage*
phpunit
/results/
phpunit*.xml

# =====================================================
# Composer
# =====================================================
vendor/

# =====================================================
# Database / Backup Safety
# =====================================================
*.sql
*.bak
*.zip

# =====================================================
# Node / Frontend (future dashboards)
# =====================================================
node_modules/
npm-debug.log
yarn.lock
package-lock.json

/public/build
/public/hot

# =====================================================
# Security Keys & Credentials
# =====================================================
*.pem
*.key
*.crt
firebase-service-account.json

# =====================================================
# IDE / Development Files
# =====================================================

# Modules Testing
_modules/*

# phpenv
.php-version

# JetBrains (PHPStorm)
.idea/
*.iml

# NetBeans
/nbproject/
/build/
/nbbuild/
/dist/
/nbdist/
/nbactions.xml
/nb-configuration.xml
/.nb-gradle/

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project
.phpintel
/api/

# VS Code
.vscode/

# =====================================================
# Misc
# =====================================================
*.log
